class DeltaForceApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(debugShowCheckedModeBanner: false, home: AuthScreen());
  }
}

class AuthScreen extends StatefulWidget {
  @override
  _AuthScreenState createState() => _AuthScreenState();
}

class _AuthScreenState extends State<AuthScreen> {
  final GoogleSignIn _googleSignIn = GoogleSignIn();
  bool hasInternet = true;

  @override
  void initState() {
    super.initState();
    _checkInternet();
  }

  Future<void> _checkInternet() async {
    var result = await Connectivity().checkConnectivity();
    setState(() {
      hasInternet = result != ConnectivityResult.none;
    });
  }

  Future<void> _handleSignIn() async {
    await _checkInternet();
    if (!hasInternet) {
      ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("No internet! Use WiFi or Mobile Data to play")));
      return;
    }
    try {
      await _googleSignIn.signIn();
      Navigator.pushReplacement(context, MaterialPageRoute(builder: (context) => LobbyScreen()));
    } catch (e) {
      ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("Sign in failed: $e")));
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: Container(
        decoration: BoxDecoration(image: DecorationImage(image: NetworkImage("https://images.unsplash.com/photo-1532336414038-cf19250c5757?q=80&w=2070"), fit: BoxFit.cover, colorFilter: ColorFilter.mode(Colors.black.withOpacity(0.5), BlendMode.darken))),
        child: Center(child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
          Text("DELTA FORCE", style: TextStyle(fontSize: 36, fontWeight: FontWeight.bold, color: Colors.white, letterSpacing: 4)),
          SizedBox(height: 10),
          Text("Tactical Shooter", style: TextStyle(color: Colors.grey[300], fontSize: 16)),
          SizedBox(height: 80),
          if (!hasInternet) Padding(padding: EdgeInsets.all(20), child: Text("⚠️ No internet connection\nConnect WiFi or Mobile Data", textAlign: TextAlign.center, style: TextStyle(color: Colors.redAccent, fontSize: 16))),
          ElevatedButton.icon(onPressed: hasInternet ? _handleSignIn : null, icon: Icon(Icons.login), label: Text("Sign in with Google", style: TextStyle(fontSize: 16)), style: ElevatedButton.styleFrom(backgroundColor: Colors.white, foregroundColor: Colors.black, padding: EdgeInsets.symmetric(horizontal: 40, vertical: 14), shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)))),
          SizedBox(height: 20),
          Text("Required: Internet to play", style: TextStyle(color: Colors.grey[400], fontSize: 12)),
        ])),
      ),
    );
  }
}

class LobbyScreen extends StatefulWidget {
  @override
  _LobbyScreenState createState() => _LobbyScreenState();
}

class _LobbyScreenState extends State<LobbyScreen> with TickerProviderStateMixin {
  bool isRecording = false;
  bool showLoading = false;
  bool showMatchmaking = false;
  bool showDisconnect = false;
  bool isMusicPlaying = true;
  double buttonScale = 1.0;
  String matchmakingText = "Finding players... 1/4";
  String signalStrength = "Good";
  int ping = 42;
  int fps = 60;
  double deviceTemp = 38.5;
  String serverRegion = "EU-West";
  int ramUsed = 0;
  int ramTotal = 8;

  late AnimationController _rankSpinController;
  late AnimationController _statsCounterController;
  late AnimationController _seasonProgressController;
  late AnimationController _radarController;
  late AudioPlayer _audioPlayer;
  late AudioPlayer _musicPlayer;

  int kdValue = 0;
  int winsValue = 0;
  int killsValue = 0;
  double seasonProgress = 0.0;

  int _frameCount = 0;
  DateTime _lastTime = DateTime.now();

  @override
  void initState() {
    super.initState();
    _audioPlayer = AudioPlayer();
    _musicPlayer = AudioPlayer();
    _playLobbyMusic();

    _rankSpinController = AnimationController(duration: Duration(seconds: 2), vsync: this)..forward();
    _radarController = AnimationController(duration: Duration(seconds: 2), vsync: this)..repeat();

    _statsCounterController = AnimationController(duration: Duration(seconds: 2), vsync: this);
    _statsCounterController.addListener(() {
      setState(() {
        kdValue = (3.8 * _statsCounterController.value).toInt();
        winsValue = (127 * _statsCounterController.value).toInt();
        killsValue = (4210 * _statsCounterController.value).toInt();
      });
    });

    _seasonProgressController = AnimationController(duration: Duration(seconds: 3), vsync: this);
    _seasonProgressController.addListener(() {
      setState(() {
        seasonProgress = 0.42 * _seasonProgressController.value;
      });
    });

    Future.delayed(Duration(seconds: 1), () {
      _statsCounterController.forward();
      _seasonProgressController.forward();
    });

    _monitorConnection();
    _simulatePing();
    _startFPSCounter();
    _simulateTemp();
    _simulateRam();
    _pickServer();
  }

  void _pickServer() {
    List<String> servers = ["EU-West", "US-East", "Asia-SG", "MENA-Dubai", "SA-Brazil"];
    setState(() {
      serverRegion = servers[DateTime.now().second % servers.length];
    });
  }

  void _simulateTemp() async {
    while (mounted) {
      await Future.delayed(Duration(seconds: 3));
      setState(() {
        if (signalStrength == "Weak") {
          deviceTemp = 42.0 + (DateTime.now().millisecond % 50) / 10;
        } else if (fps < 40) {
          deviceTemp = 40.0 + (DateTime.now().millisecond % 30) / 10;
        } else {
          deviceTemp = 36.0 + (DateTime.now().millisecond % 40) / 10;
        }
      });
    }
  }

  void _simulateRam() async {
    while (mounted) {
      await Future.delayed(Duration(seconds: 2));
      setState(() {
        if (showMatchmaking) {
          ramUsed = 85 + (DateTime.now().millisecond % 15);
        } else if (fps < 40) {
          ramUsed = 70 + (DateTime.now().millisecond % 20);
        } else {
          ramUsed = 45 + (DateTime.now().millisecond % 25);
        }
      });
    }
  }

  void _startFPSCounter() {
    Future.doWhile(() async {
      await Future.delayed(Duration(milliseconds: 16));
      _frameCount++;
      var now = DateTime.now();
      if (now.difference(_lastTime).inSeconds >= 1) {
        setState(() {
          fps = _frameCount;
          if (signalStrength == "Weak") {
            fps = 35 + (DateTime.now().millisecond % 20);
          } else if (signalStrength == "Lost") {
            fps = 10;
          } else {
            fps = 58 + (DateTime.now().millisecond % 4);
          }
        });
        _frameCount = 0;
        _lastTime = now;
      }
      return mounted;
    });
  }

  void _simulatePing() async {
    while (mounted) {
      await Future.delayed(Duration(seconds: 2));
      var result = await Connectivity().checkConnectivity();

      if (result == ConnectivityResult.none) {
        setState(() {
          ping = 999;
          signalStrength = "Lost";
          showDisconnect = true;
        });
      } else if (result == ConnectivityResult.mobile) {
        setState(() {
          ping = 120 + (DateTime.now().millisecond % 100);
          signalStrength = ping > 200 ? "Weak" : "Good";
          if (ping > 400) showDisconnect = true;
        });
      } else {
        setState(() {
          ping = 30 + (DateTime.now().millisecond % 40);
          signalStrength = "Good";
          showDisconnect = false;
        });
      }
    }
  }

  void _monitorConnection() async {
    while (mounted) {
      await Future.delayed(Duration(seconds: 3));
      var result = await Connectivity().checkConnectivity();
      if (result == ConnectivityResult.none) {
        setState(() {
          signalStrength = "Lost";
          showDisconnect = true;
        });
      }
    }
  }

  Future<void> _playLobbyMusic() async {
    await _musicPlayer.setReleaseMode(ReleaseMode.loop);
    await _musicPlayer.setVolume(0.4);
    await _musicPlayer.play(AssetSource('lobby_music.mp3'));
  }

  void _toggleMusic() {
    setState(() => isMusicPlaying = !isMusicPlaying);
    isMusicPlaying ? _musicPlayer.resume() : _musicPlayer.pause();
  }

  Future<void> _playTapSound() async {
    await _audioPlayer.play(AssetSource('click.mp3'));
  }

  void _animateButton() {
    setState(() => buttonScale = 0.95);
    Future.delayed(Duration(milliseconds: 100), () {
      setState(() => buttonScale = 1.0);
    });
  }

  void startMission() async {
    _playTapSound();
    _animateButton();

    var result = await Connectivity().checkConnectivity();
    if (result == ConnectivityResult.none) {
      ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("No internet! Connect WiFi or Mobile Data")));
      return;
    }

    setState(() => showMatchmaking = true);

    List<String> texts = ["Finding players... 1/4", "Finding players... 2/4", "Finding players... 3/4", "Finding players... 4/4", "Match found! Loading..."];

    for (int i = 0; i < texts.length; i++) {
      await Future.delayed(Duration(seconds: 1));
      var conn = await Connectivity().checkConnectivity();
      if (conn == ConnectivityResult.none) {
        setState(() {
          showMatchmaking = false;
          showDisconnect = true;
          signalStrength = "Lost";
        });
        return;
      }
      setState(() => matchmakingText = texts[i]);
    }

    setState(() {
      showMatchmaking = false;
      showLoading = true;
    });

    Future.delayed(Duration(seconds: 3), () {
      setState(() => showLoading = false);
      showWeaponMenu();
    });
  }

